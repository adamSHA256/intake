# Database
DATABASE_URL=postgres://intake:intake@db:5432/intake
PGPOOL_MAX=10

# App
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Retell webhook signing secret (the API key Retell uses to sign X-Retell-Signature).
# Get this from the Retell dashboard when wiring real traffic.
# Leave empty in demo mode — the webhook falls back to bearer auth via DEMO_BEARER_TOKEN.
WEBHOOK_SIGNATURE_SECRET=

# Bearer tokens
DEMO_BEARER_TOKEN=change-me-demo-token
API_BEARER_TOKEN=change-me-api-token

# Demo lifecycle (displayed in README only; no enforcement in code)
DEMO_TAKEDOWN_DATE=2026-06-30

# Shown as links on the landing page. Leave empty if you don't want repo links visible.
GITHUB_REPO_URL=
